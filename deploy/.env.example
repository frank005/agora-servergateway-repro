# Copy to deploy/.env and fill in credentials. Root docker-compose.yml uses env_file: deploy/.env

# Agora credentials for the repro / join-channel run
AGORA_APP_ID=your_app_id
AGORA_CHANNEL_ID=your_channel_name
# AGORA_TOKEN=   # not required (project uses App ID when token auth disabled)
# AGORA_UID=0    # optional; default 0. For string user account: AGORA_USE_STRING_UID=1 and set AGORA_UID to your account string
# AGORA_USE_STRING_UID=1   # 1 = string user account mode (not only numeric uid)
# AGORA_AREA_CODE=GLOB   # GLOB | OVS | hex (service area; default GLOB)
# AGORA_SET_SERVICE_CHANNEL_PROFILE=0  # 1 = set channelProfile on AgoraServiceConfiguration / agora_service_config
# AGORA_SERVICE_CHANNEL_PROFILE=LIVE_BROADCASTING
# AGORA_SET_SERVICE_AUDIO_SCENARIO=0   # 1 = set audioScenario on service config
# AGORA_SERVICE_AUDIO_SCENARIO=DEFAULT # DEFAULT | CHATROOM | … or 0–10
# AGORA_SET_CLIENT_ROLE_TYPE=1  # 1 = set role type on connection config, 0 = do not set
# AGORA_CLIENT_ROLE_TYPE=AUDIENCE  # AUDIENCE or BROADCASTER (also accepts 2 or 1)
# AGORA_SET_CHANNEL_PROFILE=0  # 1 = set channel profile on *connection* config, 0 = do not set
# AGORA_CHANNEL_PROFILE=COMMUNICATION  # connection-level: COMMUNICATION or LIVE_BROADCASTING (also 0 or 1)
AGORA_JOIN_DURATION_SEC=20   # seconds in channel; 0 = until Ctrl+C
AGORA_RECEIVE_VIDEO=0    # 1 = subscribe to video /  0 = no video subscription
AGORA_SEND_AUDIO=0    # 1 = publish audio /  0 = no publish audio
AGORA_SEND_VIDEO=0    # 1 = publish video / 0 = no publish video

# --- Observers & volume (turn on for multi-speaker volume logs + subscribe callbacks) ---
# Set 1 so remote speaker volume is reported (SDK playout path). 0 can yield only [audio-volume][local].
AGORA_ENABLE_AUDIO_RECORDING_OR_PLAYOUT=1
AGORA_ENABLE_AUDIO_VOLUME_INDICATION=1
AGORA_VOLUME_INDICATION_INTERVAL_MS=1000
AGORA_VOLUME_INDICATION_SMOOTH=3
AGORA_VOLUME_INDICATION_VAD=0
# AGORA_SET_LOCAL_USER_AUDIO_SCENARIO=0  # 1 = setAudioScenario / agora_local_user_set_audio_scenario
# AGORA_LOCAL_USER_AUDIO_SCENARIO=DEFAULT
AGORA_REGISTER_AUDIO_OBSERVER=1
AGORA_REGISTER_CONN_OBSERVER=0
AGORA_REGISTER_LOCAL_USER_OBSERVER=1
AGORA_LU_CB_AUDIO_SUB=1
AGORA_LU_CB_VIDEO_SUB=1
AGORA_LU_CB_VOLUME_IND=1
# AGORA_LU_CB_USER_INFO_UPDATED=0  # 1 = onUserInfoUpdated (noisy)

# --- PCM dump (optional; mount host dir over AGORA_DUMP_PCM_DIR to retrieve files) ---
# AGORA_DUMP_BEFORE_MIXING_PCM=0
# AGORA_DUMP_PLAYBACK_PCM=0
# AGORA_DUMP_PCM_DIR=/tmp/agora_pcm_dump

# AGORA_REPRO_STOP_AFTER=   # init | create_local_audio_track | connect | publish  - stop after that step (for bisect; connect/publish require AGORA_CHANNEL_ID)
# AGORA_THREAD_PRIORITY=   # 0|1|2|3|4|5  - set deprecated threadPriority (0=LOWEST 2=NORMAL 5=CRITICAL); if SDK honors it, may avoid RT
# AGORA_ENCRYPTION_ENABLE=   # 0|1  - enable built-in media encryption (0=off, 1=on)
# AGORA_ENCRYPTION_MODE=    # 1-8 or name (7=AES-128-GCM2 8=AES-256-GCM2). Required when encryption enabled
# AGORA_ENCRYPTION_SECRET=    # encryption key (required when encryption enabled)
# AGORA_ENCRYPTION_SALT=   # Base64-encoded 32-byte salt (required for AES-*-GCM2 modes)
AGORA_LOG_FILE=/app/agora_sdk.log   #  where the SDK writes the log inside the container (default: /app/agora_sdk.log)
AGORA_HOST_LOG_FILE=/tmp   # where the helper script copies the log on the host (default: ./logs/agora_sdk.log)
# AGORA_REPRO_IMAGE=servergateway-repro   # docker image for deploy/run_with_logs.sh (optional; default servergateway-repro)
AGORA_REPRO_IMPL=v2   # Comment this out for repro_pthread_init (C++ API)
